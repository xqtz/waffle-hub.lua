    Title.Size = UDim2.new(1,-100,1,0)
    Title.BackgroundTransparency = 1
    Title.Text = title
    Title.TextColor3 = CurrentTheme.Text
    Title.TextScaled = true
    Title.Font = Enum.Font.GothamBold
    Title.Parent = TopBar

    local MinBtn = Instance.new("TextButton")
    MinBtn.Size = UDim2.new(0,30,0,30)
    MinBtn.Position = UDim2.new(1,-130,0.5,-15)
    MinBtn.BackgroundTransparency = 1
    MinBtn.Text = "□"
    MinBtn.TextColor3 = CurrentTheme.Text
    MinBtn.TextSize = 20
    MinBtn.Parent = TopBar
    MinBtn.MouseButton1Click:Connect(function() MainFrame.Visible = not MainFrame.Visible end)

    local MaxBtn = Instance.new("TextButton")
    MaxBtn.Size = UDim2.new(0,30,0,30)
    MaxBtn.Position = UDim2.new(1,-90,0.5,-15)
    MaxBtn.BackgroundTransparency = 1
    MaxBtn.Text = "□"
    MaxBtn.TextColor3 = CurrentTheme.Text
    MaxBtn.TextSize = 20
    MaxBtn.Parent = TopBar

    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Size = UDim2.new(0,30,0,30)
    CloseBtn.Position = UDim2.new(1,-50,0.5,-15)
    CloseBtn.BackgroundTransparency = 1
    CloseBtn.Text = "✕"
    CloseBtn.TextColor3 = Color3.fromRGB(255,80,80)
    CloseBtn.TextSize = 22
    CloseBtn.Parent = TopBar
    CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

    local Sidebar = RoundedFrame(MainFrame, UDim2.new(0,160,1,-50), CurrentTheme.Sidebar, 16)
    Sidebar.Position = UDim2.new(0,0,0,50)

    local Content = RoundedFrame(MainFrame, UDim2.new(1,-160,1,-50), CurrentTheme.Background, 16)
    Content.Position = UDim2.new(0,160,0,50)

    self.ScreenGui = ScreenGui
    self.MainFrame = MainFrame
    self.Sidebar = Sidebar
    self.Content = Content
    self.Tabs = {}
    self.CurrentTab = nil

    local SearchBox = Instance.new("TextBox")
    SearchBox.Size = UDim2.new(1,-20,0,30)
    SearchBox.Position = UDim2.new(0,10,0,10)
    SearchBox.PlaceholderText = "Search..."
    SearchBox.BackgroundColor3 = Color3.fromRGB(30,30,35)
    SearchBox.TextColor3 = Color3.new(1,1,1)
    SearchBox.Font = Enum.Font.Gotham
    SearchBox.Parent = Sidebar

    MainFrame.Visible = true
    TweenService:Create(MainFrame, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0,680,0,480)}):Play()
    TweenService:Create(MainFrame, TweenInfo.new(0.6), {BackgroundTransparency = 0.15}):Play()

    function self:NewTab(tabName)
        local tab = {}
        local button = RoundedButton(Sidebar, tabName, CurrentTheme.Button)
        button.Position = UDim2.new(0,10,0,0)
        button.Size = UDim2.new(1,-20,0,42)

        local tabContent = RoundedFrame(Content, UDim2.new(1,0,1,0), CurrentTheme.Background, 16)
        tabContent.Visible = false

        button.MouseButton1Click:Connect(function()
            if self.CurrentTab then self.CurrentTab.Content.Visible = false end
            tabContent.Visible = true
            self.CurrentTab = tab
        end)

        tab.Content = tabContent
        tab.Sections = {}
        table.insert(self.Tabs, tab)
        if #self.Tabs == 1 then
            tabContent.Visible = true
            self.CurrentTab = tab
        end
        return tab
    end

    function self:NewSection(tab, sectionName)
        local section = {}
        local sectionFrame = RoundedFrame(tab.Content, UDim2.new(1,-24,0,40), CurrentTheme.Sidebar, 8)
        sectionFrame.Position = UDim2.new(0,12,0,0)

        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1,-20,1,0)
        title.BackgroundTransparency = 1
        title.Text = sectionName
        title.TextColor3 = CurrentTheme.Text
        title.TextXAlignment = Enum.TextXAlignment.Left
        title.Font = Enum.Font.GothamBold
        title.TextSize = 15
        title.Parent = sectionFrame

        section.Frame = sectionFrame
        section.Elements = {}

        function section:NewButton(text, info, callback)
            local btn = RoundedButton(sectionFrame, text, CurrentTheme.Button)
            btn.Size = UDim2.new(1,-20,0,42)
            btn.Parent = sectionFrame
            table.insert(section.Elements, btn)
            return btn
        end

        function section:NewLabel(text)
            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(1,-20,0,30)
            lbl.BackgroundTransparency = 1
            lbl.Text = text
            lbl.TextColor3 = CurrentTheme.SecondaryText
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 14
            lbl.Parent = sectionFrame
            table.insert(section.Elements, lbl)
            return lbl
        end

        function section:NewToggle(text, callback)
            local tog = SpringToggle(sectionFrame, text, false, callback)
            table.insert(section.Elements, tog)
            return tog
        end

        function section:NewSlider(text, min, max, default, callback)
            local sl = DraggableSlider(sectionFrame, text, min, max, default, callback)
            table.insert(section.Elements, sl)
            return sl
        end

        return section
    end

    function self:Notify(title, text, duration)
        local notif = RoundedFrame(ScreenGui, UDim2.new(0,280,0,80), CurrentTheme.Button, 12)
        notif.Position = UDim2.new(1,-10,-1,10)
        notif.BackgroundTransparency = 0.1

        local nTitle = Instance.new("TextLabel")
        nTitle.Size = UDim2.new(1,0,0,25)
        nTitle.BackgroundTransparency = 1
        nTitle.Text = title
        nTitle.TextColor3 = CurrentTheme.Text
        nTitle.Font = Enum.Font.GothamBold
        nTitle.TextSize = 14
        nTitle.Parent = notif

        local nText = Instance.new("TextLabel")
        nText.Size = UDim2.new(1,0,0,40)
        nText.Position = UDim2.new(0,0,0,25)
        nText.BackgroundTransparency = 1
        nText.Text = text
        nText.TextColor3 = CurrentTheme.SecondaryText
        nText.Font = Enum.Font.Gotham
        nText.TextSize = 13
        nText.Parent = notif

        TweenService:Create(notif, TweenInfo.new(0.4), {Position = UDim2.new(1,-10,0,10)}):Play()
        task.delay(duration or 3, function()
            TweenService:Create(notif, TweenInfo.new(0.4), {Position = UDim2.new(1,-10,-1,10)}):Play()
            task.wait(0.4)
            notif:Destroy()
        end)
    end

    self.Keybinds = {}
    UserInputService.InputBegan:Connect(function(i, g)
        if g then return end
        for _, bind in pairs(self.Keybinds) do
            if bind.key == i.Key and bind.callback then bind.callback() end
        end
    end)

    function self:SaveConfig()
        local cfg = {}
        for _, tab in pairs(self.Tabs) do
            for _, sec in pairs(tab.Sections or {}) do
                for _, elem in pairs(sec.Elements or {}) do
                    if elem.State ~= nil then cfg[elem.Title or "toggle"] = elem.State end
                    if elem.Value ~= nil then cfg[elem.Title or "slider"] = elem.Value end
                end
            end
        end
        writefile("aestheticlib_config.json", game:GetService("HttpService"):JSONEncode(cfg))
        self:Notify("Config", "Saved to aestheticlib_config.json")
    end

    function self:LoadConfig()
        if isfile("aestheticlib_config.json") then
            local cfg = game:GetService("HttpService"):JSONDecode(readfile("aestheticlib_config.json"))
            for _, tab in pairs(self.Tabs) do
                for _, sec in pairs(tab.Sections or {}) do
                    for _, elem in pairs(sec.Elements or {}) do
                        if cfg[elem.Title or "toggle"] ~= nil then elem:Update(cfg[elem.Title or "toggle"]) end
                        if cfg[elem.Title or "slider"] ~= nil then elem:Update(cfg[elem.Title or "slider"]) end
                    end
                end
            end
            self:Notify("Config", "Loaded from file")
        end
    end

    MainFrame.Visible = true
    return self
end

