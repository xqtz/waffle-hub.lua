local CurrentTheme = Themes.Dark

local function RoundedFrame(parent, size, color, corner)
    local f = Instance.new("Frame")
    f.Size = size or UDim2.new(1,0,1,0)
    f.BackgroundColor3 = color or Color3.new(1,1,1)
    f.BorderSizePixel = 0
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, corner or 12)
    c.Parent = f
    f.Parent = parent
    return f
end

local function RoundedButton(parent, text, color, callback)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1,0,0,42)
    b.BackgroundColor3 = color or CurrentTheme.Button
    b.Text = text
    b.TextColor3 = CurrentTheme.Text
    b.Font = Enum.Font.GothamSemibold
    b.TextSize = 14
    b.Parent = parent
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0,8)
    c.Parent = b
    b.MouseButton1Click:Connect(callback or function() end)
    b.MouseEnter:Connect(function() TweenService:Create(b, TweenInfo.new(0.2), {BackgroundColor3 = CurrentTheme.Hover}):Play() end)
    b.MouseLeave:Connect(function() TweenService:Create(b, TweenInfo.new(0.2), {BackgroundColor3 = CurrentTheme.Button}):Play() end)
    return b
end

local function SpringToggle(parent, text, default, callback)
    local t = {State = default or false}
    local frame = RoundedFrame(parent, UDim2.new(1,0,0,42), CurrentTheme.Button)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.7,0,1,0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = CurrentTheme.Text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.Parent = frame

    local switch = RoundedFrame(frame, UDim2.new(0,42,0,22), Color3.fromRGB(80,80,80))
    local knob = RoundedFrame(switch, UDim2.new(0,18,0,18), Color3.new(1,1,1))
    knob.Position = UDim2.new(0,2,0.5,-9)

    local function toggle()
        t.State = not t.State
        callback(t.State)
        TweenService:Create(switch, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundColor3 = t.State and CurrentTheme.Accent or Color3.fromRGB(80,80,80)}):Play()
        TweenService:Create(knob, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = t.State and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9)}):Play()
    end

    frame.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then toggle() end
    end)

    function t:Update(newText)
        label.Text = newText
    end
    return t
end

local function DraggableSlider(parent, text, min, max, default, callback)
    local s = {Value = default or 0}
    local frame = RoundedFrame(parent, UDim2.new(1,0,0,52), CurrentTheme.Button)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,0,20)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. s.Value
    label.TextColor3 = CurrentTheme.Text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.Parent = frame

    local bar = RoundedFrame(frame, UDim2.new(1,-30,0,8), Color3.fromRGB(60,60,70))
    bar.Position = UDim2.new(0,15,0.65,0)
    local fill = RoundedFrame(bar, UDim2.new(0,0,1,0), CurrentTheme.Accent)
    local knob = RoundedFrame(bar, UDim2.new(0,16,0,16), Color3.new(1,1,1))
    knob.Position = UDim2.new(0, -8, 0.5, -8)

    local dragging = false
    local function update(pos)
        local p = math.clamp((pos - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        s.Value = math.floor(min + (max - min) * p)
        label.Text = text .. ": " .. s.Value
        fill.Size = UDim2.new(p,0,1,0)
        knob.Position = UDim2.new(p, -8, 0.5, -8)
        callback(s.Value)
    end

    bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true update(i.Position) end end)
    UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i.Position) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    function s:Update(newValue)
        s.Value = newValue
        label.Text = text .. ": " .. s.Value
        local p = (s.Value - min) / (max - min)
        fill.Size = UDim2.new(p,0,1,0)
        knob.Position = UDim2.new(p, -8, 0.5, -8)
    end
    return s
end

function Library:CreateLib(title, themeName)
    local self = setmetatable({}, Library)
    CurrentTheme = Themes[themeName] or Themes.Dark

    local blur = Instance.new("BlurEffect")
