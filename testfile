end

function Library:NewTab(tabName)
    local tab = {}
    
    local TabButton = Instance.new("TextButton")
    TabButton.Size = UDim2.new(1, -20, 0, 42)
    TabButton.Position = UDim2.new(0, 10, 0, 0)
    TabButton.BackgroundColor3 = CurrentTheme.Button
    TabButton.Text = tabName
    TabButton.TextColor3 = CurrentTheme.Text
    TabButton.Font = Enum.Font.GothamSemibold
    TabButton.TextSize = 14
    TabButton.Parent = self.Sidebar
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 8)
    BtnCorner.Parent = TabButton
    
    local TabContent = Instance.new("ScrollingFrame")
    TabContent.Size = UDim2.new(1, 0, 1, 0)
    TabContent.BackgroundTransparency = 1
    TabContent.ScrollBarThickness = 6
    TabContent.ScrollBarImageColor3 = CurrentTheme.Accent
    TabContent.Visible = false
    TabContent.Parent = self.ContentHolder
    
    local ContentList = Instance.new("UIListLayout")
    ContentList.SortOrder = Enum.SortOrder.LayoutOrder
    ContentList.Padding = UDim.new(0, 12)
    ContentList.Parent = TabContent
    
    TabButton.MouseButton1Click:Connect(function()
        if self.CurrentTab then
            self.CurrentTab.Content.Visible = false
        end
        TabContent.Visible = true
        self.CurrentTab = tab
    end)
    
    tab.Content = TabContent
    tab.Sections = {}
    table.insert(self.Tabs, tab)
    
    if #self.Tabs == 1 then
        TabContent.Visible = true
        self.CurrentTab = tab
    end
    
    return tab
end

function Library:NewSection(tab, sectionName)
    local section = {}
    
    local SectionFrame = Instance.new("Frame")
    SectionFrame.Size = UDim2.new(1, -24, 0, 40)
    SectionFrame.BackgroundColor3 = CurrentTheme.Sidebar
    SectionFrame.BorderSizePixel = 0
    SectionFrame.Parent = tab.Content
    
