    SecCorner.Parent = SectionFrame
    
    local SecTitle = Instance.new("TextLabel")
    SecTitle.Size = UDim2.new(1, -20, 1, 0)
    SecTitle.Position = UDim2.new(0, 10, 0, 0)
    SecTitle.BackgroundTransparency = 1
    SecTitle.Text = sectionName
    SecTitle.TextColor3 = CurrentTheme.Text
    SecTitle.TextXAlignment = Enum.TextXAlignment.Left
    SecTitle.Font = Enum.Font.GothamBold
    SecTitle.TextSize = 15
    SecTitle.Parent = SectionFrame
    
    section.Frame = SectionFrame
    section.TitleLabel = SecTitle
    section.Elements = {}
    
    function section:UpdateSection(newTitle)
        SecTitle.Text = newTitle
    end
    
    function section:NewLabel(text)
        local label = {}
        local LabelFrame = Instance.new("Frame")
        LabelFrame.Size = UDim2.new(1, -20, 0, 32)
        LabelFrame.BackgroundTransparency = 1
        LabelFrame.Parent = SectionFrame
        
        local LabelText = Instance.new("TextLabel")
